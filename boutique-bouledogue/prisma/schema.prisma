generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PuppyStatus {
  AVAILABLE
  RESERVED
  SOLD
  /// Portee annoncee / chiots a naitre
  COMING_SOON
}

enum ReservationStatus {
  PENDING
  PAID
  CANCELLED
}

model Puppy {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  gender         String
  color          String
  birthDate      DateTime
  priceCents     Int
  /// Si true, afficher "Sur demande" au lieu du prix (priceCents ignore pour l'affichage).
  priceOnRequest Boolean       @default(false)
  /// Mis en avant sur l'accueil (chiots disponibles en vedette).
  featured       Boolean       @default(false)
  /// Acompte fixe en cents CAD (optionnel). Sinon calcul auto via RESERVATION_DEPOSIT_*.
  depositCents   Int?
  description    String
  pedigree       String
  city           String
  status         PuppyStatus   @default(AVAILABLE)
  coverImage     String
  gallery        String[]
  reservations   Reservation[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Reservation {
  id                    String            @id @default(cuid())
  puppyId               String
  customerName          String
  customerEmail         String
  customerPhone         String
  message               String?
  /// Acompte facture Stripe (cents CAD), enregistre a la creation de la session.
  depositAmountCents    Int?
  status                ReservationStatus @default(PENDING)
  stripeCheckoutSession String?           @unique
  stripePaymentIntent   String?
  puppy                 Puppy             @relation(fields: [puppyId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  content   String
  createdAt DateTime @default(now())
}
