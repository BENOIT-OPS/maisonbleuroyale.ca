generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Puppy {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  gender         String
  color          String
  birthDate      DateTime
  priceCents     Int
  priceOnRequest Boolean       @default(false)
  featured       Boolean       @default(false)
  depositCents   Int?
  description    String
  pedigree       String
  city           String
  status         PuppyStatus   @default(AVAILABLE)
  coverImage     String
  gallery        String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reservations   Reservation[]
}

model Reservation {
  id                    String            @id @default(cuid())
  puppyId               String
  customerName          String
  customerEmail         String
  customerPhone         String
  message               String?
  depositAmountCents    Int?
  status                ReservationStatus @default(PENDING)
  stripeCheckoutSession String?           @unique
  stripePaymentIntent   String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  puppy                 Puppy             @relation(fields: [puppyId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  content   String
  createdAt DateTime @default(now())
}

enum PuppyStatus {
  AVAILABLE
  RESERVED
  SOLD
  /// Portee annoncee / chiots a naitre
  COMING_SOON
}

enum ReservationStatus {
  PENDING
  PAID
  CANCELLED
}
